# ============================================================
# TailorMe environment configuration
#
# Copy this file to `.env.local` and fill in the values for the
# services you want to enable. The app runs in SIMULATED DEMO MODE
# for any service whose keys are absent — so you can fill these in
# one at a time and the rest of the site keeps working.
#
#   - Supabase keys absent  -> auth + data are the demo localStorage mock
#   - Stripe keys absent     -> "Pay" runs the demo success animation
#   - Anthropic key absent   -> the audit wizard runs the simulated pipeline
#
# After editing .env.local, restart `npm run dev`.
# See docs/SETUP.md for step-by-step provisioning.
# ============================================================

# ---------- App ----------
# Public base URL of this app (used for OAuth + Stripe redirects).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------- Supabase (auth + database + storage) ----------
# Create a project at https://supabase.com, then Project Settings -> API.
# Run supabase/migrations/0001_init.sql in the SQL editor (see docs/SETUP.md).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key (Project Settings -> API). SERVER-ONLY — never exposed to
# the browser. Used by the Stripe webhook to grant credits.
SUPABASE_SERVICE_ROLE_KEY=

# ---------- Stripe (credit-pack payments) ----------
# Dashboard -> Developers -> API keys.
STRIPE_SECRET_KEY=
# Set after creating the webhook endpoint (see docs/SETUP.md). For local dev,
# `stripe listen --forward-to localhost:3000/api/stripe/webhook` prints it.
STRIPE_WEBHOOK_SECRET=
# Publishable key (optional; not required for hosted Checkout).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ---------- LLM provider (the /apply tailoring + review pipeline) ----------
# NEVER paste a key into a chat or commit it — put it here in .env.local only.
# Which provider runs the pipeline: "anthropic" (default) or "openai".
LLM_PROVIDER=anthropic

# Anthropic — https://console.anthropic.com -> API keys.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI — https://platform.openai.com -> API keys. Models are assigned per
# use case to maximize usage: the cheap model handles the structured score +
# review steps, the stronger model handles the quality-sensitive tailor step.
OPENAI_API_KEY=
OPENAI_MODEL_TAILOR=gpt-4.1
OPENAI_MODEL_FAST=gpt-4.1-mini

# Set to 1 to enable the /api/compare eval route (runs both providers side by
# side; requires BOTH keys). Off by default — it makes 6 billed calls per run.
COMPARE_ENABLED=

# ---------- Abuse / cost guardrails (all optional; sensible defaults) ----------
# Set to 1 to turn OFF rate limiting (handy for local dev). Leave empty in prod.
RATE_LIMIT_DISABLED=
# Input-size caps (bound tokens per call).
MAX_POSTING_CHARS=8000
MAX_RESUME_CHARS=24000
# Free (unauthenticated) fit-score audits, per IP.
FREE_AUDIT_PER_HOUR=3
FREE_AUDIT_PER_DAY=8
# Global circuit breaker — caps total free audits/day across all users.
FREE_AUDIT_GLOBAL_PER_DAY=2000
# Resume-parse uploads, per IP.
PARSE_PER_HOUR=8
PARSE_PER_DAY=20
# Full tailored runs per signed-in account per day (credits already cap total).
FULL_RUNS_PER_DAY=60
# Stripe checkout attempts per account per hour.
CHECKOUT_PER_HOUR=20

# ---------- LaTeX compile service (optional, for real moderncv PDFs) ----------
# A self-hosted endpoint that accepts { tex, engine } and returns a PDF. Keep it
# on your own infrastructure so resume content never leaves it (GDPR). Without
# it, the app serves the in-app moderncv print view (browser "Save as PDF").
# A ready-to-run container lives in ./compile-service (see its README).
LATEX_COMPILE_URL=
# Shared secret — must match COMPILE_TOKEN on the compile service (if set there).
LATEX_COMPILE_TOKEN=
