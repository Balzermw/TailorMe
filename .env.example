# ============================================================
# TailorMe environment configuration
#
# Copy this file to `.env.local` and fill in the values for the
# services you want to enable. The app runs in SIMULATED DEMO MODE
# for any service whose keys are absent — so you can fill these in
# one at a time and the rest of the site keeps working.
#
#   - Supabase keys absent  -> auth + data are the demo localStorage mock
#   - Stripe keys absent     -> "Pay" runs the demo success animation
#   - Anthropic key absent   -> the audit wizard runs the simulated pipeline
#
# After editing .env.local, restart `npm run dev`.
# See docs/SETUP.md for step-by-step provisioning.
# ============================================================

# ---------- App ----------
# Public base URL of this app (used for OAuth + Stripe redirects).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------- Supabase (auth + database + storage) ----------
# Create a project at https://supabase.com, then Project Settings -> API.
# Run supabase/migrations/0001_init.sql in the SQL editor (see docs/SETUP.md).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key (Project Settings -> API). SERVER-ONLY — never exposed to
# the browser. Used by the Stripe webhook to grant credits.
SUPABASE_SERVICE_ROLE_KEY=

# ---------- Stripe (credit-pack payments) ----------
# Dashboard -> Developers -> API keys.
STRIPE_SECRET_KEY=
# Set after creating the webhook endpoint (see docs/SETUP.md). For local dev,
# `stripe listen --forward-to localhost:3000/api/stripe/webhook` prints it.
STRIPE_WEBHOOK_SECRET=
# Publishable key (optional; not required for hosted Checkout).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ---------- Anthropic (the /apply tailoring + review pipeline) ----------
# https://console.anthropic.com -> API keys.
ANTHROPIC_API_KEY=
# Optional model override. Defaults to claude-sonnet-4-6.
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---------- LaTeX compile service (optional, for real moderncv PDFs) ----------
# A self-hosted endpoint that accepts { tex, engine } and returns a PDF. Keep it
# on your own infrastructure so resume content never leaves it (GDPR). Without
# it, the app serves the in-app moderncv print view (browser "Save as PDF").
# See docs/SETUP.md for a ready-to-run container.
LATEX_COMPILE_URL=
