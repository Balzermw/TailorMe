# TailorMe / ResMe E2E environment.
# Copy to .env.e2e.local for private local runs. Never commit .env.e2e.local.

NEXT_PUBLIC_APP_URL=http://127.0.0.1:3100
E2E_BASE_URL=http://127.0.0.1:3100
E2E_TEST_MODE=1

# Default: deterministic, no live provider spend.
RUN_LIVE_AI_E2E=0
REQUIRE_LIVE_AI_PARSE=0
RUN_REAL_RESUME_CORPUS=0
CAPTURE_REAL_RESUME_SCREENSHOTS=0
DISABLE_ANALYTICS_IN_E2E=0

# Private real-resume corpus. Leave blank for committed/default runs.
REAL_RESUME_CORPUS_DIR=
REAL_RESUME_MANIFEST=
REAL_RESUME_BATCH_START=0
REAL_RESUME_BATCH_LIMIT=50
REAL_RESUME_FILTER_TYPE=
REAL_RESUME_FILTER_CATEGORY=
REAL_RESUME_RETRY_FAILURES_ONLY=0
REAL_RESUME_LIVE_AI_LIMIT=10

# Force safe demo defaults unless a live test explicitly opts in.
RATE_LIMIT_DISABLED=1
CREDITS_DISABLED=1
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
LATEX_COMPILE_URL=
